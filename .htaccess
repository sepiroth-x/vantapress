<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect all requests to /public directory
    # This makes domain.com/ serve from domain.com/public/ transparently
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect sensitive files and directories
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to sensitive file extensions
<FilesMatch "\.(env|log|md|json|lock|yml|yaml|xml|sql|gitignore|gitattributes)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to Laravel directories (except public)
RedirectMatch 403 ^/(app|bootstrap|config|database|resources|routes|storage|vendor|tests|Modules)/

# Block access to composer files
<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|artisan)$">
    Order allow,deny
    Deny from all
</FilesMatch>
